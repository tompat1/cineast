  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.43.0",
    "@playwright/test": "^1.61.1",
    "vite": "^6.4.3",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "lenis": "^1.3.25"
  }
}
