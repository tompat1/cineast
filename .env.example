# Baseline Environment Variables
# Copy this file to .env and configure secrets as needed.

# Application Keys
# API_KEY=your_key_here

# Cloudflare CMS bootstrap token for the first admin setup route
# BOOTSTRAP_ADMIN_TOKEN=replace-with-a-long-random-secret

# Optional local/frontend API origin for the CMS client
# VITE_CINEAST_API_BASE=http://127.0.0.1:8788
